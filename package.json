{
    "name": "twitch-channel-point-auto-claimer-react",
    "version": "1.2.0",
    "type": "module",
    "scripts": {
        "test": "bun test",
        "test:watch": "bun test --watch",
        "prebuild": "bun run test && bun run scripts/build-content.js",
        "build:chrome": "BROWSER=chrome bun run scripts/build.js chrome",
        "build:firefox": "BROWSER=firefox bun run scripts/build.js firefox",
        "build": "bun run build:chrome && bun run build:firefox",
        "dev:chrome": "BROWSER=chrome bun run scripts/build.js chrome --watch",
        "dev:firefox": "BROWSER=firefox bun run scripts/build.js firefox --watch",
        "clean": "rm -rf dist-chrome dist-firefox src/content/content.js",
        "verify": "bun run scripts/verify-build.js"
    },
    "dependencies": {
        "react": "^18.2.0",
        "react-dom": "^18.2.0"
    },
    "devDependencies": {
        "@types/react": "^18.2.43",
        "@types/react-dom": "^18.2.17",
        "@vitejs/plugin-react": "^4.2.1",
        "dotenv": "^17.4.2",
        "vite": "^5.0.8",
        "vite-plugin-static-copy": "^1.0.1"
    }
}
